#!/bin/bash
# run-stage-6.sh — 并发调度开发 agent，无依赖任务同时执行
# 进度存储：本地 JSON 文件（零外部依赖）
# 用法：./run-stage-6.sh <项目名> <项目目录>
# 示例：./run-stage-6.sh film-auth .contracts/film-auth
# 兼容 macOS bash 3.x

set -eo pipefail

AGENTS_ROOT="/Users/sunwenyong/.openclaw/agents"
PIPELINE_ROOT="$AGENTS_ROOT/agent-pipeline"
DISPATCH_TASK="$PIPELINE_ROOT/scripts/dispatch-task.sh"
SESSION_HEALTH="$PIPELINE_ROOT/scripts/session-health.sh"

# 任务超时时间（秒）— 单个任务最长执行时间
TASK_TIMEOUT=7200  # 2小时

# 卡住检测时间（秒）— 超过此时间无更新视为卡住
STUCK_THRESHOLD=600  # 10分钟

PROJECT="$1"
PROJECT_DIR="$2"

if [ -z "$PROJECT" ] || [ -z "$PROJECT_DIR" ]; then
  echo "用法: $0 <项目名> <项目目录>"
  echo "示例: $0 film-auth .contracts/film-auth"
  exit 1
fi

TASK_LIST="$PROJECT_DIR/pipeline/5/TASK-LIST.md"
PROGRESS_FILE="$PROJECT_DIR/pipeline/6/progress.json"

if [ ! -f "$TASK_LIST" ]; then
  echo "❌ 任务清单不存在: $TASK_LIST"
  exit 1
fi

mkdir -p "$PROJECT_DIR/pipeline/6"

if [ ! -f "$PROGRESS_FILE" ]; then
  echo '{}' > "$PROGRESS_FILE"
fi

# ─── 临时文件清理 + 信号处理 ───
TEMP_FILES=()
CHILD_PIDS=()

cleanup() {
  # 清理临时文件
  for f in "${TEMP_FILES[@]}"; do
    [ -f "$f" ] && rm -f "$f"
  done
  # 清理孤儿进程
  for pid in "${CHILD_PIDS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
}
trap cleanup EXIT
trap 'echo "⚠️ 收到中断信号，清理中..."; cleanup; exit 130' INT TERM

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🚀 阶段6：开发执行（并发调度）"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  项目: $PROJECT"
echo "  任务清单: $TASK_LIST"
echo "  进度文件: $PROGRESS_FILE"
echo "  并发 agent: dev1, dev2, dev3"
echo ""

# ─── 启动前 Session 健康检查 ───
echo "🔍 启动前 Session 健康检查..."
for agent in dev1 dev2 dev3; do
  bash "$SESSION_HEALTH" "$PROJECT" "$agent" "$PROJECT_DIR" check 2>/dev/null || true
done
echo ""

# 并发安全的进度操作（文件锁）
LOCKDIR="$PROGRESS_FILE.lockdir"

# 跨平台文件锁（macOS 兼容）
acquire_lock() {
  local lockdir="$1"
  local timeout="${2:-10}"
  local i=0
  while ! mkdir "$lockdir" 2>/dev/null; do
    i=$((i + 1))
    if [ "$i" -ge "$timeout" ]; then
      return 1
    fi
    sleep 1
  done
  return 0
}

release_lock() {
  rmdir "$1" 2>/dev/null
}

task_set_status() {
  local task_id="$1"
  local status="$2"
  local agent="$3"
  local error="${4:-}"
  local ts=$(date +%s)

  acquire_lock "$LOCKDIR" 30 || { echo "⚠️ 获取锁超时: $task_id"; return 1; }
  python3 -c "
import json, sys
try:
    with open('$PROGRESS_FILE') as f:
        data = json.load(f)
except:
    data = {}
key = '$task_id'
if key not in data:
    data[key] = {}
data[key].update({'status': '$status', 'agent': '$agent', 'updated_at': $ts, 'error': '$error'})
try:
    with open('$PROGRESS_FILE', 'w') as f:
        json.dump(data, f, indent=2)
except Exception as e:
    print(f'⚠️ 写入进度失败: {e}', file=sys.stderr)
" 2>/dev/null
  release_lock "$LOCKDIR"
}

task_get_status() {
  local task_id="$1"
  python3 -c "
import json
try:
    with open('$PROGRESS_FILE') as f:
        data = json.load(f)
    print(data.get('$task_id', {}).get('status', 'pending'))
except:
    print('pending')
" 2>/dev/null || echo "pending"
}

get_completed_list() {
  python3 -c "
import json
try:
    with open('$PROGRESS_FILE') as f:
        data = json.load(f)
    print(','.join(k for k, v in data.items() if isinstance(v, dict) and v.get('status') == 'completed'))
except:
    print('')
" 2>/dev/null || echo ""
}

# 解析 TASK-LIST.md，提取所有任务（含并发组）
parse_tasks() {
  python3 << 'PYEOF'
import re, os, tempfile

task_list_path = os.environ.get("TASK_LIST", "")

with open(task_list_path) as f:
    content = f.read()

task_pattern = re.compile(
    r'### (T-\d+):\s*(.+?)(?=\n### T-\d+:|\n## |\Z)',
    re.DOTALL
)

for match in task_pattern.finditer(content):
    task_id = match.group(1)
    task_body = match.group(2).strip()

    deps_match = re.search(r'\*\*依赖\*\*:\s*(.+)', task_body)
    deps = []
    if deps_match:
        deps_str = deps_match.group(1).strip()
        if deps_str != "无":
            deps = [d.strip() for d in re.findall(r'T-\d+', deps_str)]

    dev_match = re.search(r'\*\*开发者\*\*:\s*(.+)', task_body)
    dev_type = dev_match.group(1).strip() if dev_match else "后端"

    group_match = re.search(r'\*\*并发组\*\*:\s*(.+)', task_body)
    group = group_match.group(1).strip() if group_match else "default"

    # 使用确定性路径，便于增量上下文跟踪
    task_files_dir = os.path.join(os.path.dirname(os.path.dirname(task_list_path)), '6', '.task-files')
    os.makedirs(task_files_dir, exist_ok=True)
    tmp_path = os.path.join(task_files_dir, f'{task_id}.md')
    with open(tmp_path, 'w') as tmp:
        tmp.write(f"### {task_id}: {task_body}")
    tmp_path = tmp_path  # 重命名变量保持兼容

    deps_str = ",".join(deps) if deps else "none"
    print(f"{task_id}|{deps_str}|{dev_type}|{group}|{tmp_path}")

PYEOF
}

# 检查依赖是否满足
deps_satisfied() {
  local task_deps="$1"
  local completed_list="$2"

  if [ "$task_deps" = "none" ]; then
    return 0
  fi

  IFS=',' read -ra DEPS <<< "$task_deps"
  for dep in "${DEPS[@]}"; do
    if ! echo ",$completed_list," | grep -q ",$dep,"; then
      return 1
    fi
  done
  return 0
}

# 验证 agent-id 是否合法
is_valid_agent() {
  local agent="$1"
  case "$agent" in
    dev1|dev2|dev3) return 0 ;;
    *) return 1 ;;
  esac
}

# 构建依赖上下文文件
build_dep_context() {
  local task_deps="$1"
  local task_reports_dir="$PROJECT_DIR/pipeline/6/task-reports"

  if [ "$task_deps" = "none" ] || [ -z "$task_deps" ]; then
    echo ""
    return
  fi

  local context_file=$(mktemp /tmp/dep-context-XXXXX.md)
  local has_content=false

  IFS=',' read -ra DEPS <<< "$task_deps"
  for dep in "${DEPS[@]}"; do
    local report_file="$task_reports_dir/${dep}.md"
    if [ -f "$report_file" ]; then
      echo "" >> "$context_file"
      cat "$report_file" >> "$context_file"
      echo "" >> "$context_file"
      has_content=true
    fi
  done

  if [ "$has_content" = true ]; then
    echo "$context_file"
  else
    rm -f "$context_file"
    echo ""
  fi
}

# 查找所有依赖满足且未完成的任务，输出可调度列表（含并发组）
find_ready_tasks() {
  local task_lines="$1"
  local completed_list="$2"

  while IFS='|' read -r task_id deps dev_type group task_file; do
    [ -z "$task_id" ] && continue

    status=$(task_get_status "$task_id")
    if [ "$status" = "completed" ] || [ "$status" = "failed" ] || [ "$status" = "running" ]; then
      continue
    fi

    if deps_satisfied "$deps" "$completed_list"; then
      echo "${task_id}|${deps}|${dev_type}|${group}|${task_file}"
    fi
  done <<< "$task_lines"
}

# 单个任务执行（在子 shell 中运行，不阻塞主进程）
run_single_task() {
  local task_id="$1"
  local deps="$2"
  local dev_type="$3"
  local task_file="$4"
  local agent_id="$5"
  local result_file="$6"

  local session_name="${PROJECT}-${agent_id}"

  # 构建依赖上下文
  local dep_ctx_file=$(build_dep_context "$deps")

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 任务 $task_id ($dev_type) → $agent_id"
  echo "  依赖: $deps"
  echo "  Session: $session_name"
  if [ -n "$dep_ctx_file" ]; then
    echo "  依赖上下文: 已注入"
  fi
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  task_set_status "$task_id" "running" "$agent_id"

  # 在后台运行，记录 PID 供卡住检测
  bash "$DISPATCH_TASK" "$PROJECT" "$agent_id" "$task_file" "$PROJECT_DIR" "$task_id" "$dep_ctx_file" &
  local task_pid=$!

  # 将 PID 写入进度文件
  acquire_lock "$LOCKDIR" 10 || true
  python3 << PYEOF
import json, os
try:
    with open("${PROGRESS_FILE}") as f:
        data = json.load(f)
    if "${task_id}" in data and isinstance(data["${task_id}"], dict):
        data["${task_id}"]["pid"] = ${task_pid}
        with open("${PROGRESS_FILE}", "w") as f:
            json.dump(data, f, indent=2)
except:
    pass
PYEOF
  release_lock "$LOCKDIR"

  wait $task_pid
  local dispatch_exit=$?

  if [ $dispatch_exit -eq 0 ]; then
    task_set_status "$task_id" "completed" "$agent_id"
    echo "✅ $task_id 完成 ($agent_id)"
    echo "success" > "$result_file"
  else
    local exit_msg=""
    [ $dispatch_exit -eq 124 ] && exit_msg="（超时）"
    echo "⚠️ $task_id 失败${exit_msg}，换 agent 重试..."
    # 重试：重置 session + 换一个 agent
    bash "$SESSION_HEALTH" "$PROJECT" "$agent_id" "$PROJECT_DIR" reset 2>/dev/null || true

    # 选择不同的 agent 重试
    local retry_agent="$agent_id"
    for a in $ALL_AGENTS; do
      if [ "$a" != "$agent_id" ]; then
        retry_agent="$a"
        break
      fi
    done
    echo "  🔄 重试 agent: $agent_id → $retry_agent"

    bash "$DISPATCH_TASK" "$PROJECT" "$retry_agent" "$task_file" "$PROJECT_DIR" "$task_id" "$dep_ctx_file"
    local retry_exit=$?
    if [ $retry_exit -eq 0 ]; then
      task_set_status "$task_id" "completed" "$retry_agent"
      echo "✅ $task_id 重试成功 ($retry_agent)"
      echo "success" > "$result_file"
    else
      local retry_msg=""
      [ $retry_exit -eq 124 ] && retry_msg="（超时）"
      # 重试失败 → 重置两个 agent 的 session，避免坏 session 影响后续任务
      echo "🔄 重置 session: ${PROJECT}-${agent_id}, ${PROJECT}-${retry_agent}"
      bash "$SESSION_HEALTH" "$PROJECT" "$agent_id" "$PROJECT_DIR" reset 2>/dev/null || true
      bash "$SESSION_HEALTH" "$PROJECT" "$retry_agent" "$PROJECT_DIR" reset 2>/dev/null || true
      task_set_status "$task_id" "failed" "$retry_agent" "重试仍失败${retry_msg}"
      echo "❌ $task_id 重试仍失败${retry_msg} ($retry_agent)"
      echo "  💡 提示：要跳过此任务，执行: echo '$task_id' >> $PROJECT_DIR/pipeline/6/.skip-tasks"
      echo "failed" > "$result_file"
    fi
  fi

  rm -f "$dep_ctx_file"
  # 不删除 task_file，保留用于增量上下文跟踪
}

# 主循环（按并发组调度：同组串行，不同组并发）
MAX_ROUNDS=100
ROUND=0
ALL_AGENTS="dev1 dev2 dev3"

# ─── 跳过任务（手动干预用，级联跳过依赖链） ───
# 用法：echo "T-003" >> $PROJECT_DIR/pipeline/6/.skip-tasks
# 跳过 T-003 时，所有依赖 T-003 的任务也自动跳过
load_skip_tasks() {
  local skip_file="$PROJECT_DIR/pipeline/6/.skip-tasks"
  if [ -f "$skip_file" ]; then
    cat "$skip_file" | tr '\n' ' ' | sed 's/ $//'
  fi
}

# 计算级联跳过：给定跳过列表，找出所有依赖被跳过任务的任务
cascade_skip() {
  local skip_list="$1"
  local task_lines="$2"

  # 反复扩展，直到没有新增（处理多级依赖）
  local current_skips="$skip_list"
  local changed=true
  while [ "$changed" = true ]; do
    changed=false
    while IFS='|' read -r tid deps dtype grp tfile; do
      [ -z "$tid" ] && continue
      # 已经在跳过列表中的跳过
      echo "$current_skips" | grep -qwE "(^|\s)${tid}(\s|$)" && continue
      # 检查依赖是否被跳过
      if [ "$deps" != "none" ]; then
        IFS=',' read -ra DEP_LIST <<< "$deps"
        for dep in "${DEP_LIST[@]}"; do
          if echo "$current_skips" | grep -qwE "(^|\s)${dep}(\s|$)"; then
            current_skips="$current_skips $tid"
            changed=true
            break
          fi
        done
      fi
    done <<< "$task_lines"
  done

  echo "$current_skips"
}

# 主循环启动时，处理跳过列表（级联）
SKIP_TASKS=$(load_skip_tasks)
if [ -n "$SKIP_TASKS" ]; then
  TASK_LINES=$(TASK_LIST="$TASK_LIST" parse_tasks)
  CASCADED_SKIPS=$(cascade_skip "$SKIP_TASKS" "$TASK_LINES")
  if [ "$CASCADED_SKIPS" != "$SKIP_TASKS" ]; then
    echo "⏭️  跳过列表级联扩展: $SKIP_TASKS → $CASCADED_SKIPS"
  else
    echo "⏭️  检测到跳过列表: $SKIP_TASKS"
  fi
  for skip_id in $CASCADED_SKIPS; do
    [ -z "$skip_id" ] && continue
    local_skip_status=$(task_get_status "$skip_id")
    if [ "$local_skip_status" = "pending" ] || [ "$local_skip_status" = "failed" ]; then
      task_set_status "$skip_id" "completed" "skipped"
      echo "  ⏭️  $skip_id 标记为跳过（completed/skipped）"
    fi
  done
fi

while [ $ROUND -lt $MAX_ROUNDS ]; do
  ROUND=$((ROUND + 1))

  COMPLETED_LIST=$(get_completed_list)
  TASK_LINES=$(TASK_LIST="$TASK_LIST" parse_tasks)

  if [ -z "$TASK_LINES" ]; then
    echo ""
    echo "✅ 所有任务已完成！"
    break
  fi

  # 检测卡住的任务（双重检测：updated_at + 进程存活）
  acquire_lock "$LOCKDIR" 10 || true
  python3 -c "
import json, time, sys, os, signal
try:
    with open('$PROGRESS_FILE') as f:
        data = json.load(f)
except:
    sys.exit(0)
now = int(time.time())
changed = False
for k, v in data.items():
    if isinstance(v, dict) and v.get('status') == 'running':
        updated = v.get('updated_at', 0)
        pid = v.get('pid', 0)
        # 检查1：超过 STUCK_THRESHOLD 无更新
        if now - updated > $STUCK_THRESHOLD:
            data[k]['status'] = 'failed'
            data[k]['error'] = 'stuck_timeout'
            changed = True
            print(f'⚠️ {k}: 检测到卡住 ({now - updated}s)，标记为 failed')
            # 尝试终止卡住的进程
            if pid > 0:
                try:
                    os.kill(pid, signal.SIGTERM)
                    print(f'  🔪 已发送 SIGTERM 到 PID {pid}')
                except:
                    pass
        # 检查2：进程已死但状态还是 running（agent 崩溃）
        elif pid > 0:
            try:
                os.kill(pid, 0)  # 检查进程是否存活
            except OSError:
                data[k]['status'] = 'failed'
                data[k]['error'] = 'process_dead'
                changed = True
                print(f'⚠️ {k}: 进程 {pid} 已死但状态为 running，标记为 failed')
if changed:
    try:
        with open('$PROGRESS_FILE', 'w') as f:
            json.dump(data, f, indent=2)
    except:
        pass
" 2>/dev/null
  release_lock "$LOCKDIR"

  # 找出所有可调度任务
  READY_TASKS=$(find_ready_tasks "$TASK_LINES" "$COMPLETED_LIST")

  if [ -z "$READY_TASKS" ]; then
    RUNNING_COUNT=0
    while IFS='|' read -r task_id deps dev_type group task_file; do
      [ -z "$task_id" ] && continue
      s=$(task_get_status "$task_id")
      [ "$s" = "running" ] && RUNNING_COUNT=$((RUNNING_COUNT + 1))
    done <<< "$TASK_LINES"

    if [ "$RUNNING_COUNT" -gt 0 ]; then
      echo "⏳ 有 $RUNNING_COUNT 个任务运行中，等待..."
      sleep 5
      continue
    fi

    FAILED_COUNT=0
    REMAINING=0
    while IFS='|' read -r task_id deps dev_type group task_file; do
      [ -z "$task_id" ] && continue
      s=$(task_get_status "$task_id")
      [ "$s" = "pending" ] && REMAINING=$((REMAINING + 1))
      [ "$s" = "failed" ] && FAILED_COUNT=$((FAILED_COUNT + 1))
    done <<< "$TASK_LINES"

    if [ "$REMAINING" -eq 0 ] && [ "$FAILED_COUNT" -eq 0 ]; then
      echo ""
      echo "✅ 所有任务已完成！"
      break
    elif [ "$FAILED_COUNT" -gt 0 ]; then
      echo ""
      echo "⚠️ 有 $FAILED_COUNT 个任务失败"
      echo "  💡 要跳过失败任务让后续继续，执行: echo 'T-xxx' >> $PROJECT_DIR/pipeline/6/.skip-tasks"
      echo "  💡 然后重新运行本脚本，跳过的任务会自动标记 completed"
      break
    else
      echo ""
      echo "⏳ 没有依赖满足的任务可执行，可能存在循环依赖"
      break
    fi
  fi

  # 按并发组分组，每组取第一个就绪任务
  declare -A GROUP_FIRST_TASK
  while IFS='|' read -r task_id deps dev_type group task_file; do
    [ -z "$task_id" ] && continue
    if [ -z "${GROUP_FIRST_TASK[$group]+_}" ]; then
      GROUP_FIRST_TASK[$group]="${task_id}|${deps}|${dev_type}|${group}|${task_file}"
    fi
  done <<< "$READY_TASKS"

  # 分配 agent：每个并发组分配一个 agent
  declare -A TASK_DISPATCH_LIST
  declare -A AGENT_BUSY
  for a in $ALL_AGENTS; do
    AGENT_BUSY[$a]=0
  done

  DISPATCH_COUNT=0
  for group in "${!GROUP_FIRST_TASK[@]}"; do
    # 从任务中获取指定的 agent-id
    IFS='|' read -r tid deps dtype grp tf <<< "${GROUP_FIRST_TASK[$group]}"
    assigned=""

    # 优先使用任务指定的 agent-id
    if is_valid_agent "$dtype"; then
      if [ "${AGENT_BUSY[$dtype]}" = "0" ]; then
        assigned="$dtype"
        AGENT_BUSY[$dtype]=1
      fi
    fi

    # 指定 agent 忙碌时，找其他空闲 agent
    if [ -z "$assigned" ]; then
      for a in $ALL_AGENTS; do
        if [ "${AGENT_BUSY[$a]}" = "0" ]; then
          assigned="$a"
          AGENT_BUSY[$a]=1
          break
        fi
      done
    fi

    if [ -z "$assigned" ]; then
      break  # 没有空闲 agent
    fi

    TASK_DISPATCH_LIST["$group"]="${GROUP_FIRST_TASK[$group]}|$assigned"
    DISPATCH_COUNT=$((DISPATCH_COUNT + 1))
  done

  if [ "$DISPATCH_COUNT" -eq 0 ]; then
    echo "⏳ 所有 agent 都在忙，等待..."
    sleep 5
    unset GROUP_FIRST_TASK
    unset TASK_DISPATCH_LIST
    unset AGENT_BUSY
    continue
  fi

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🚀 并发调度 $DISPATCH_COUNT 个任务（$DISPATCH_COUNT 个并发组）"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # 并发执行
  declare -A RESULT_FILES
  for group in "${!TASK_DISPATCH_LIST[@]}"; do
    IFS='|' read -r task_id deps dev_type grp task_file agent_id <<< "${TASK_DISPATCH_LIST[$group]}"
    result_file=$(mktemp /tmp/result-XXXXX.txt)
    RESULT_FILES[$task_id]="$result_file"
    TEMP_FILES+=("$result_file")

    echo "  📋 $task_id ($grp) → $agent_id"
    run_single_task "$task_id" "$deps" "$dev_type" "$task_file" "$agent_id" "$result_file" &
    CHILD_PIDS+=($!)
  done

  # 等待所有并发任务完成（带超时，防止一个卡死阻塞全部）
  WAIT_TIMEOUT=${TASK_TIMEOUT:-7200}
  WAIT_START=$(date +%s)
  ANY_ALIVE=true
  while [ "$ANY_ALIVE" = true ]; do
    ANY_ALIVE=false
    for pid in "${CHILD_PIDS[@]}"; do
      if kill -0 "$pid" 2>/dev/null; then
        ANY_ALIVE=true
        break
      fi
    done

    if [ "$ANY_ALIVE" = false ]; then
      break
    fi

    NOW=$(date +%s)
    ELAPSED=$((NOW - WAIT_START))
    if [ "$ELAPSED" -gt "$WAIT_TIMEOUT" ]; then
      echo ""
      echo "❌ 并发任务等待超时（${WAIT_TIMEOUT}s），强制终止残留进程"
      for pid in "${CHILD_PIDS[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
          echo "  🔪 终止 PID $pid"
          kill -TERM "$pid" 2>/dev/null || true
        fi
      done
      sleep 2
      # 确保终止
      for pid in "${CHILD_PIDS[@]}"; do
        kill -0 "$pid" 2>/dev/null && kill -KILL "$pid" 2>/dev/null || true
      done
      break
    fi

    sleep 10
  done
  CHILD_PIDS=()

  # 统计本轮结果
  ROUND_SUCCESS=0
  ROUND_FAILED=0
  for task_id in "${!RESULT_FILES[@]}"; do
    result_file="${RESULT_FILES[$task_id]}"
    if [ -f "$result_file" ]; then
      result=$(cat "$result_file")
      [ "$result" = "success" ] && ROUND_SUCCESS=$((ROUND_SUCCESS + 1))
      [ "$result" = "failed" ] && ROUND_FAILED=$((ROUND_FAILED + 1))
      rm -f "$result_file"
    fi
  done

  echo ""
  echo "📊 本轮结果: 成功 $ROUND_SUCCESS, 失败 $ROUND_FAILED"

  unset GROUP_FIRST_TASK
  unset TASK_DISPATCH_LIST
  unset AGENT_BUSY
  unset RESULT_FILES

  if [ "$ROUND_FAILED" -gt 0 ]; then
    echo "⚠️ 有失败任务，继续调度其余任务..."
  fi
done

# 最终报告
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📊 阶段6执行报告"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
FINAL_C=$(python3 -c "
import json
try:
    d=json.load(open('$PROGRESS_FILE'))
    print(sum(1 for v in d.values() if isinstance(v,dict) and v.get('status')=='completed'))
except:
    print(0)
" 2>/dev/null || echo 0)
FINAL_F=$(python3 -c "
import json
try:
    d=json.load(open('$PROGRESS_FILE'))
    print(sum(1 for v in d.values() if isinstance(v,dict) and v.get('status')=='failed'))
except:
    print(0)
" 2>/dev/null || echo 0)
FINAL_S=$(python3 -c "
import json
try:
    d=json.load(open('$PROGRESS_FILE'))
    print(sum(1 for v in d.values() if isinstance(v,dict) and v.get('status')=='completed' and v.get('agent')=='skipped'))
except:
    print(0)
" 2>/dev/null || echo 0)
echo "  已完成: $FINAL_C（其中跳过: $FINAL_S）"
echo "  失败: $FINAL_F"

if [ "$FINAL_F" -gt 0 ]; then
  # 列出失败任务详情
  python3 -c "
import json
try:
    d=json.load(open('$PROGRESS_FILE'))
    failed = [(k, v.get('error','未知'), v.get('agent','?')) for k,v in d.items() if isinstance(v,dict) and v.get('status')=='failed']
    print('  ❌ 失败任务详情：')
    for tid, err, ag in failed:
        print(f'    {tid}: {err} (agent: {ag})')
    print()
    print('  💡 处理方式：')
    print('    跳过任务: echo \"T-xxx\" >> $PROJECT_DIR/pipeline/6/.skip-tasks')
    print('    然后重跑: bash $0 $PROJECT $PROJECT_DIR')
except:
    pass
" 2>/dev/null
  exit 1
else
  if [ "$FINAL_S" -gt 0 ]; then
    echo ""
    echo "  ⚠️ 有 $FINAL_S 个任务被跳过，请确认是否可接受"
  fi
  echo ""
  echo "  ✅ 全部完成！运行 pipeline-check.sh 6 验证"
  exit 0
fi
