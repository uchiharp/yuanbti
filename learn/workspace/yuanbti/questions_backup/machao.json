          "S6": 2
        },
        "tendency": "L"
      },
      {
        "label": "B",
        "text": "看情况，小背叛可以原谅，大背叛不行",
        "scores": {
          "S6": 2.5,
          "S2": 1
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "背叛一次就够了，信任碎了就是碎了",
        "scores": {
