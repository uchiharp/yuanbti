    "route_hint": null,
    "city_hint": "广陵",
    "text": "守城期间士族散布谣言动摇军心。孙策当众质问：「嘴上说着要投袁术，身体又一动不敢动，该说你是贱呢还是贱呢？」面对明面上的敌人，你的风格是——",
    "options": [
      {
        "label": "A",
        "text": "暗中收集证据，找合适的时机一举拿下",
        "scores": {
          "S7": 2,
          "S1": 1
        },
        "tendency": "L"
      },
      {
        "label": "B",
        "text": "当面对峙，但措辞留有余地",
        "scores": {
          "S7": 3,
          "S1": 3
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "当众开骂，一字一句戳到对方脸上",
        "scores": {
          "S7": 5,
          "S1": 1
        },
        "tendency": "H"
      }
    ],
    "reveal": "孙策的选择：当众怒骂「媚上欺下，贱人」——锋芒毕露。"
  },
  {
    "id": "q_sunce_04",
    "dimension": "S3",
    "cross_dimension": null,
    "type": "story_known",
    "source_character": "孙策",
    "source_story": "广陵守城·围城",
    "route_hint": null,
    "city_hint": "广陵",
    "text": "守城物资紧缺，有人建议节省开支。孙策却说：「给你的给你的！钱嘛，一句话的事。」面对手头紧张的情况，你的态度是——",
    "options": [
      {
        "label": "A",
        "text": "精打细算，每一笔钱都要花在刀刃上",
        "scores": {
          "S3": 5,
          "S8": 4,
          "S1": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "该省的省，该花的花，量入为出",
        "scores": {
          "S3": 3
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "钱的事不叫事，花就是了",
        "scores": {
          "S3": 1,
          "S6": 2
        },
        "tendency": "L"
      }
    ],
    "reveal": "孙策的选择：「钱嘛，一句话的事」——对金钱几乎不在意。"
  },
  {
