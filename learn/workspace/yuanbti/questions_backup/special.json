[
  {
    "id": "special_01",
    "calibration_range": "entry",
    "dimension": "S1",
    "cross_dimension": null,
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "乱世之中，你认为成大事者最需要什么？",
    "options": [
      {
        "label": "A",
        "text": "一支能征善战的军队，和一个值得追随的主公",
        "scores": {
          "S1": 1
        },
        "tendency": "L"
      },
      {
        "label": "B",
        "text": "看得比所有人远三步的头脑，和不露声色的耐心",
        "scores": {
          "S1": 5
        },
        "tendency": "H"
      },
      {
        "label": "C",
        "text": "知己知彼，随机应变，能打则打不能打则走",
        "scores": {
          "S1": 3
        },
        "tendency": "M"
      }
    ],
    "reveal": "直来直去的人信奉力量，步步为营的人信奉布局。你的选择，暴露了你处理问题的第一反应。"
  },
  {
    "id": "special_02",
    "calibration_range": "entry",
    "dimension": "S2",
    "cross_dimension": null,
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "「人这一辈子，能被一个人记得，就够了。」听到这句话，你的第一反应是——",
    "options": [
      {
        "label": "A",
        "text": "太矫情了，活着的人还有很多事要做",
        "scores": {
          "S2": 1
        },
        "tendency": "L"
      },
      {
        "label": "B",
        "text": "说得对，如果没有牵挂，活着跟死了",
        "scores": {
          "S2": 5
        },
        "tendency": "H"
      },
      {
        "label": "C",
        "text": "记得就好，但也不必执着于此",
        "scores": {
          "S2": 3
        },
        "tendency": "M"
      }
    ],
    "reveal": "情感的内敛与外露，从来不是对错之分——是你选择让世界看到多少真实的自己。"
  },
  {
    "id": "special_03",
    "calibration_range": "entry",
    "dimension": "S3",
    "cross_dimension": null,
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "有人送你一箱黄金，条件是你帮一个小忙。你的反应是——",
    "options": [
      {
        "label": "A",
        "text": "先看是什么忙——值得做的事不收钱也会做",
        "scores": {
          "S3": 2
        },
        "tendency": "L"
      },
      {
        "label": "B",
        "text": "黄金收下，忙也帮——天下没有白吃的午餐，各取所需",
        "scores": {
          "S3": 5
        },
        "tendency": "H"
      },
      {
        "label": "C",
        "text": "问清楚来龙去脉，再决定收不收、帮不帮，值得深思",
        "scores": {
          "S3": 3
        },
        "tendency": "M"
      }
    ],
    "reveal": "对金钱的态度，折射的是你对「等价交换」这个规则的信奉程度。"
  },
  {
