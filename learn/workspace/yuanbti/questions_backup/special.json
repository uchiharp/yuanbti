    "calibration_range": "entry",
    "dimension": "S4",
    "cross_dimension": null,
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "「你知道我每天演多少场戏吗？」——你如何理解这句话？",
    "options": [
      {
        "label": "A",
        "text": "活得真累，不如做真实的自己",
