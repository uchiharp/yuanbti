          "S6": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "吕布的命令从不含糊。但他后来又托付广陵王照顾张辽和阿蝉——命令是给外人的，托付是给自己的。"
  },
  {
    "id": "q_lvbu_10",
    "dimension": "S9",
    "cross_dimension": null,
    "type": "story_anon",
    "source_character": "吕布",
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
