[
  {
    "id": "q_lvbu_01",
    "dimension": "S5",
    "cross_dimension": null,
    "type": "story_known",
    "source_character": "吕布",
    "source_story": "密探故事03",
    "route_hint": [
      "西凉线"
    ],
    "city_hint": "冀州",
    "text": "「我从长安杀出来，你见到我第一句话，居然是问我为什么要杀人？」——吕布站在城门前，浑身浴血。如果你是他，面对广陵王的质问——",
    "options": [
      {
        "label": "A",
        "text": "「不杀人，我拿什么走到这里？」",
        "scores": {
          "S5": 5,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "「我杀的是该杀之人。」",
        "scores": {
          "S5": 3.5
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "「你若觉得不对，就去告官。」",
        "scores": {
          "S5": 2,
          "S9": 1,
          "S6": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "吕布的回答是：「我从长安杀出来。」他没有解释，也没有辩驳。行动本身就是他的全部语言。"
  },
  {
    "id": "q_lvbu_02",
    "dimension": "S5",
    "cross_dimension": null,
    "type": "story_anon",
    "source_character": "吕布",
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "你率领一支饥肠辘辘的军队路过一座城池。城中富庶，守军不过千人。粮草官来报：最多撑三日。你的选择是？",
    "options": [
      {
        "label": "A",
        "text": "攻城夺粮，活着的人才有资格讲道理。",
        "scores": {
          "S5": 5,
          "S10": 1
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "先派使者谈判，谈不成再动手。",
        "scores": {
          "S5": 3,
          "S6": 2
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "绕城而行，向后方求援，不能劫掠百姓。",
        "scores": {
          "S5": 2,
          "S6": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "这个场景来自吕布密探故事——「粮草未至，沿途的军粮，我们就自己解决了。」"
  },
  {
    "id": "q_lvbu_03",
    "dimension": "S5",
    "cross_dimension": "S9",
    "type": "story_known",
    "source_character": "吕布",
    "source_story": "密探故事03",
    "route_hint": [
      "西凉线"
    ],
    "city_hint": "冀州",
    "text": "「不用管。带走这里所有能带的，去打下一座城。」——吕布说完这句话，转头看向广陵王。如果你是吕布，战后第一时间做什么？",
    "options": [
      {
        "label": "A",
        "text": "清点战利品和伤亡，立刻下令行军，一刻不停。",
        "scores": {
          "S5": 5,
          "S8": 4,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "让将士们休整半日，伤者先处理，然后出发。",
        "scores": {
          "S5": 3
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "坐下来商议下一步战略，等所有情报汇总再行动。",
        "scores": {
          "S5": 2,
          "S3": 1,
          "S2": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "吕布的原话是：「躺在那的是袁基的医师，留给你们了，算是义气了，出发。」——上一秒还在分配战利品，下一秒已经出发。"
  },
  {
    "id": "q_lvbu_04",
    "dimension": "S5",
    "cross_dimension": "S7",
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "「能往前杀，何必往后退。」——面对一道看似无解的困局，你更认同哪种态度？",
    "options": [
      {
        "label": "A",
        "text": "困局不是用来想的，是用来杀穿的。",
        "scores": {
          "S5": 5,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "先退一步看清全貌，再决定怎么往前。",
        "scores": {
          "S5": 2.5
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "后退也是一种策略，活着才能继续打。",
        "scores": {
          "S5": 2,
          "S1": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "A来自吕布的战场哲学：「能往前杀，何必往后退。」B是多数谋士的做法。C是张辽式的务实。"
  },
  {
    "id": "q_lvbu_05",
    "dimension": "S7",
    "cross_dimension": null,
    "type": "story_known",
    "source_character": "吕布",
    "source_story": "刺董之后",
    "route_hint": [
      "西凉线"
    ],
    "city_hint": "洛阳",
    "text": "刺杀董卓之后，袁氏承诺招纳西凉军却迟迟不兑现。吕布带兵找到广陵王，要和袁氏当面对质。面对袁氏的推诿，你说什么？",
    "options": [
      {
        "label": "A",
        "text": "「去告诉他，吕布来了，要和他当面对质。」",
        "scores": {
          "S7": 5,
          "S8": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "「他的承诺，你替他做主吗？」——冷笑质问。",
        "scores": {
          "S7": 4,
          "S5": 3
        },
        "tendency": "H"
      },
      {
        "label": "C",
        "text": "「那你们两人，一个回到袁氏图谋徐州",
        "scores": {
          "S7": 5,
          "S1": 4
        },
        "tendency": "H"
      }
    ],
    "reveal": "吕布三句话连说，没有一句多余——先是叫板，再是质问，最后点出对方忘记的东西。这不是谈判，是最后通牒。"
  },
  {
    "id": "q_lvbu_06",
    "dimension": "S7",
    "cross_dimension": "S4",
    "type": "story_known",
    "source_character": "吕布",
    "source_story": "密探故事02",
    "route_hint": [
      "西凉线"
    ],
    "city_hint": "下邳",
    "text": "有人派死士假扮医师试图刺杀吕布。吕布看穿后，只说了一句话。如果是你，你会怎么说？",
    "options": [
      {
        "label": "A",
        "text": "「不要想用死士假装医师，试图拖延过去。」",
        "scores": {
          "S7": 5,
          "S4": 4,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "「我知道你们的事。」——点到为止。",
        "scores": {
          "S7": 3.5
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "沉默拔刀，让刀说话。，值得深思",
        "scores": {
          "S7": 4,
          "S5": 5,
          "S4": 3
        },
        "tendency": "H"
      }
    ],
    "reveal": "吕布的原话是：「不要想用死士假装医师，试图拖延过去。我知道你们的事。」他连嘲讽都懒得铺陈。"
  },
  {
    "id": "q_lvbu_07",
    "dimension": "S7",
    "cross_dimension": "S6",
    "type": "value",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "「你们只是没有亲自当过禽兽，但这天下的禽兽十有八九都是被你们逼出来的。」——面对一群衣冠楚楚的人指责你手段残忍，你更可能——",
    "options": [
      {
        "label": "A",
        "text": "把话甩回去：你们的手也不干净。",
        "scores": {
          "S7": 5,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "懒得解释，转身就走。",
        "scores": {
          "S7": 3
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "沉默不语，他们不会懂的。",
        "scores": {
          "S7": 2,
          "S6": 1,
          "S4": 1
        },
        "tendency": "L"
      }
    ],
    "reveal": "这是吕布最锋利的台词之一。他没有为自己辩护，而是撕开了对方伪善的面具。"
  },
  {
    "id": "q_lvbu_08",
    "dimension": "S7",
    "cross_dimension": "S9",
    "type": "extreme",
    "source_character": null,
    "source_story": null,
    "route_hint": null,
    "city_hint": null,
    "text": "以下两句话，哪句更接近你的说话风格？",
    "options": [
      {
        "label": "A",
        "text": "「话那么多，口不渴吗？」",
        "scores": {
          "S7": 5,
          "S6": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "「那是废物要考虑的东西。」",
        "scores": {
          "S7": 4
        },
        "tendency": "H"
      }
    ],
    "reveal": "两句都是吕布的原话。前者是嫌人多嘴，后者是嫌人想太多。吕布的语言风格：能一个字说完的事，绝不用两个字。"
  },
  {
    "id": "q_lvbu_09",
    "dimension": "S9",
    "cross_dimension": "S5",
    "type": "story_known",
    "source_character": "吕布",
    "source_story": "密探故事03",
    "route_hint": [
      "西凉线"
    ],
    "city_hint": "冀州",
    "text": "「那你们俩就可以分开。张辽，带她回留县。」——吕布用命令的语气安排张辽和广陵王。如果你是统帅，面对下属的私人感情——",
    "options": [
      {
        "label": "A",
        "text": "军令如山，私人感情留到战后再说。",
        "scores": {
          "S9": 5,
          "S2": 4,
          "S7": 4
        },
        "tendency": "H"
      },
      {
        "label": "B",
        "text": "先完成任务，私下会给他们安排。",
        "scores": {
          "S9": 3.5
        },
        "tendency": "M"
      },
      {
        "label": "C",
        "text": "不强求，但会给出建议。",
        "scores": {
