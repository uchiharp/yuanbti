      "text": "何须军士",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "断子之颈",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "挫子之骸",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "不亦缪乎",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "差点滑了一跤",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "人明明有左右两半",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "为什么只有一颗脑袋呢",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "弄掉了多麻烦呀",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "你说你呀",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "戎马半生",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "皮肤被风沙吹得那么粗",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "给你内廷的玉容膏",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "也不记得用",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "是我",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "不用怕",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "内廷的玉容膏",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "你有记得用吗",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "用了",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "香得我恶心",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "那好",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "开始了",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "开始了",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "刘辩",
      "text": "手握五斗米",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "谁要念你那堆软绵绵的玩意儿",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "我有我自己的",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "苍天已死",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "黄天当立",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "岁在甲子",
      "emotion": ""
    },
    {
      "type": "dialogue",
      "speaker": "？？？",
      "text": "天下大吉",
      "emotion": ""
    },
    {
      "type": "narration",
      "text": "天下大吉"
    },
