  "raw_wikitext": "<includeonly>{{面包屑|密探}}[[分类:密探]] {{#set:\n |姓名={{{姓名}}}\n |角色ID={{{角色ID}}}<!--用于抽卡模拟器-->\n |品质={{{品质}}}\n |属性={{{属性}}}\n |职业={{{职业}}}\n |标签1={{{标签1}}}\n |标签2={{{标签2}}}\n |排序={{#switch:{{{姓名}}}|飞云=2.5|绣球=2.5|{{#switch:{{{品质}}}|绝密=1|机密=2|隐密=3}}}}  \n |部门={{{部门}}}\n |关键字={{{姓名}}},{{{标签1}}},{{{标签2}}},{{{出身}}},{{{喜好}}},{{{性格}}},{{{属性1}}},{{{属性2}}},{{{属性3}}},{{{普攻}}},{{{技能}}},{{{天赋1|}}},{{{天赋2|}}},{{{天赋3|}}},{{{天赋4|}}}{{{天赋5|}}},{{{关键词|}}}|+sep=,\n <!--尝试-->\n |普攻={{{普攻}}}\n |普攻信息={{{普攻信息}}}\n |技能={{{技能}}}\n |技能1={{{技能1}}}\n |技能2={{{技能2}}}\n |技能3={{{技能3}}}\n |队长技能={{{队长技能}}}\n |队长技能信息={{{队长技能信息}}}\n |天赋1={{{天赋1}}}\n |天赋信息1={{{天赋信息1}}}\n |天赋2={{#switch:{{{职业}}}||破军=灭谛|龙盾=集谛|岐黄=道谛|#default=苦谛}}\n |天赋信息2={{#switch:{{{职业}}}||破军=普攻增伤和技能增伤提升{{颜色|绿|15}}|龙盾=免伤值提升{{颜色|绿|15}}|岐黄=自身提供的治疗效果提升{{颜色|绿|15%}}|#default=攻击力提升{{颜色|绿|15%}}}}\n |天赋3={{{天赋3}}}\n |天赋信息3={{{天赋信息3}}}\n |天赋4={{{天赋4}}}<!--初始天赋1-->\n |天赋信息4={{{天赋信息4}}}\n |天赋5={{{天赋5}}}<!--初始天赋2-->\n |天赋信息5={{{天赋信息5}}}\n |羁绊={{{羁绊}}}\n }}\n<div class=\"mitan_top\">{{{语录|{{#ask:[[{{{姓名}}}-传唤]]| ?出场语音|mainlabel=-|headers=hide}}}}}</div><div class=\"mitan_con\">\n    <div class=\"mitan_left\">\n\t<!-- 手机立绘开始-->\n\t\t<div class=\"drop-down-wrap lihui_phone\" >\n\t\t\t<div class=wrap-title>\n\t\t\t<div class=title>立绘</div>\n\t\t\t<div class=\"glyphicon icon-arrow-plus\"></div>\n\t\t\t</div>\n\t\t\t<div class=wrap-content style=\"display: block;position: relative;\">\n{{密探信息/立绘|{{{姓名}}}|{{{品质}}}|{{{部门}}}|{{{出身}}}|{{{性格}}}|{{{喜好}}}|初始立绘偏移={{{初始|0px}}}|觉醒立绘偏移={{{觉醒|0px}}}|传唤立绘偏移={{{传唤立绘|90px}}}}}\t\t\n</div></div>\n    <div class=drop-down-wrap >\n    <div class=wrap-title>\n    <div class=title>密探信息</div>\n    <div class=\"glyphicon icon-arrow-plus\"></div>\n    </div>\n    <div class=wrap-content style=\"display: block;\">\n    {| class=\"wikitable mitan_table\"\n    |-\n    |style=\"background:#f3efed;color: #5f1414;\"| 品质 || {{{品质|}}}\n    |style=\"background:#f3efed;color: #5f1414;\"| 属性 ||{{{属性|}}}\n    |-\n    |style=\"background:#f3efed;color: #5f1414;\"|特色 ||{{{标签1|}}}、{{{标签2|}}}\n    |style=\"background:#f3efed;color: #5f1414;\"|职业||{{{职业|}}}\n    |}\n    </div>\n    </div>\n    \n    <div class=drop-down-wrap >\n    <div class=wrap-title>\n    <div class=title>属性详情</div>\n    <div class=\"glyphicon icon-arrow-plus\"></div>\n    </div>\n    <div class=wrap-content style=\"display: block;\">\n    {| class=\"wikitable mitan_table\"\n    |-\n    !colspan=4|总属性\n    |-\n    |style=\"background:#f3efed;color: #5f1414;\"| 生命 ||{{{生命}}} \n    |style=\"background:#f3efed;color: #5f1414;\"| 攻击 ||{{{攻击}}}\n    |-\n    !colspan=4|探索能力\n    |-\n    |[[file:{{{纵火|}}}脸.png|link=|25px]]纵火||[[file:{{{传谣|}}}脸.png|link=|25px]]传谣\n    |[[file:{{{下毒|}}}脸.png|link=|25px]]下毒||[[file:{{{卧底|}}}脸.png|link=|25px]]卧底\n    |-\n    |[[file:{{{搜集|}}}脸.png|link=|25px]]搜集||[[file:{{{灭火|}}}脸.png|link=|25px]]灭火\n    |[[file:{{{净水|}}}脸.png|link=|25px]]净水||[[file:{{{营救|}}}脸.png|link=|25px]]营救\n    |-\n    !colspan=4|奇闻属性\n    |-\n    |style=\"background:#f3efed;color: #5f1414;\"|[[File:奇闻属性-攻击力.png|link=|30px]]{{{属性1|}}} ||{{{奇闻攻击|{{#switch:{{{品质}}}|绝密=500|机密=350|隐密=300}}}}}\n    |style=\"background:#f3efed;color: #5f1414;\"|[[File:奇闻属性-生命值.png|link=|30px]]{{{属性2|}}}||{{{奇闻生命|{{#switch:{{{品质}}}|绝密=2600|机密=1820|隐密=1570|#default=2600}}}}}\n    |-\n    |style=\"background:#f3efed;color: #5f1414;\"|[[File:奇闻属性-伤害提高.png|link=|30px]]{{{属性3|}}}||{{{奇闻其他|}}}\n    |}\n    </div>\n    </div>\n    <div class=drop-down-wrap >\n        <div class=wrap-title>\n        <div class=title>密探技能{{#if:{{{单独技能页|}}}|-{{{单独技能页|}}}| }}</div>\n        <div class=\"glyphicon icon-arrow-plus\"></div>\n        </div>\n        <div class=wrap-content style=\"display: block;\">\n        {| class=\"wikitable mitan_table\"\n        |-\n        |rowspan=\"2\"|icon\n        |style=\"background:#f3efed;color: #5f1414;\"| 普攻-{{{普攻}}}\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);\"|{{{普攻信息}}}\n        |-\n        |rowspan=\"2\"|icon\n        |style=\"background:#f3efed;color: #5f1414;\"| 技能-{{{技能}}}（消耗能量：{{{消耗能量}}}）\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);text-align: left;\"|<div style=\"padding: 10px;border-bottom: 1px solid #eee;\"><span style=\"color:#fce09b;font-weight: bold;\">等级1：</span>{{{技能1}}}</div><div style=\"padding: 10px;border-bottom: 1px solid #eee;\"><span style=\"color:#fce09b;font-weight: bold;\">等级2：</span>{{{技能2}}}</div>{{#if:{{{技能3|}}}|<div style=\"padding: 10px;border-bottom: 1px solid #eee;\"><span style=\"color:#fce09b;font-weight: bold;\">等级3：</span>{{{技能3}}}</div>|}}\n        |-\n        |rowspan=\"2\"|icon\n        |style=\"background:#f3efed;color: #5f1414;\"| 队长技能-{{{队长技能}}}\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);\"|{{{队长技能信息}}}\n        |-\n        !colspan=2|天赋\n        |-\n        |rowspan=\"2\"|1\n        |style=\"background:#f3efed;color: #5f1414;\"|{{{天赋1}}}({{颜色|红|密探2星解锁}})\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);\"|{{{天赋信息1}}}\n        |-\n        |rowspan=\"2\"|2\n        |style=\"background:#f3efed;color: #5f1414;\"|{{{天赋2}}}({{颜色|红|密探4星解锁}})\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);\"|{{{天赋信息2}}}\n        |-\n        |rowspan=\"2\"|3\n        |style=\"background:#f3efed;color: #5f1414;\"|{{{天赋3}}}({{颜色|红|密探觉醒后解锁}})\n        |-\n        |style=\"background: rgba(255, 255, 255, 0.7);\"|{{{天赋信息3}}}\n        |-\n{{#if:{{{天赋4|}}}|<tr><td rowspan=\"2\">4</td><td style=\"background:#f3efed;color: #5f1414;\">{{{天赋4|}}}({{颜色|红|{{{天赋解锁4}}}}})</td></tr><tr><td style=\"background: rgba(255, 255, 255, 0.7);\">{{{天赋信息4|}}}</td></tr>}}\n{{#if:{{{天赋5|}}}|<tr><td rowspan=\"2\">5</td><td style=\"background:#f3efed;color: #5f1414;\">{{{天赋5|}}}({{颜色|红|{{{天赋解锁5}}}}})</td></tr><tr><td style=\"background: rgba(255, 255, 255, 0.7);\">{{{天赋信息5|}}}</td></tr>}}\n|}\n</div></div>\n{{#if:{{{单独技能页|}}}|{{:{{{姓名|}}}-技能}} | }}\n<div class=drop-down-wrap >\n        <div class=wrap-title>\n        <div class=title>命盘</div>\n        <div class=\"glyphicon icon-arrow-plus\"></div>\n        </div>\n        <div class=wrap-content style=\"display: block;\">{{{命盘|}}}\n</div></div>{{密探材料表|{{{属性}}}|{{{职业}}}}} \n<div class=drop-down-wrap >\n        <div class=wrap-title>\n        <div class=title>密探化极<span style=\"position: absolute;right: 5px;font-size: 14px;\">▼展开全部▼</span></div>\n        <div class=\"glyphicon icon-arrow-plus\"></div>\n        </div>\n        <div class=wrap-content style=\"\">\n{{:{{{姓名}}}/化极表}}{{化极\n|密探={{{姓名|}}}\n|1星属性加成=生命值+0%、攻击力+0%\n|1星其他加成=大招等级+1\n<!-- 2星 -->\n|2星属性加成=生命值+5%、攻击力+5%\n|2星其他加成=解锁技能：{{{天赋1}}}\n<!-- 3星 -->\n|3星属性加成=生命值+10%、攻击力+10%\n|3星其他加成=大招等级+1\n<!-- 4星 -->\n|4星属性加成=生命值+15%、攻击力+15%\n|4星其他加成=解锁技能：{{#switch:{{{职业}}}||破军=灭谛|龙盾=集谛|岐黄=道谛|#default=苦谛}}\n<!-- 5星 -->\n|5星属性加成={{#ifeq:{{{品质|}}}|隐密||生命值+25%、攻击力+25%}}\n|5星其他加成=大招等级+1\n}}\n</div></div>\n    </div><div class=\"mitan_right\">\n<!-- 立绘-->\n\t\t<div class=\"drop-down-wrap lihui_pc\" >\n\t\t\t<div class=wrap-title>\n\t\t\t<div class=title>立绘</div>\n\t\t\t<div class=\"glyphicon icon-arrow-plus\"></div>\n\t\t\t</div>\n\t\t\t<div class=wrap-content style=\"display: block;position: relative;\">\n{{密探信息/立绘|{{{姓名}}}|{{{品质}}}|{{{部门}}}|{{{出身}}}|{{{性格}}}|{{{喜好}}}|初始立绘偏移={{{初始}}}|觉醒立绘偏移={{{觉醒}}}|传唤立绘偏移={{{传唤立绘}}}}}\t\t\t\t\t\n</div></div>\n\n<div class=drop-down-wrap >\n    <div class=wrap-title>\n    <div class=title>雀部计簿<span style=\"position: absolute;right: 5px;font-size: 14px;\">▼展开全部▼</span></div>\n    <div class=\"glyphicon icon-arrow-plus\"></div>\n    </div>\n    <div class=wrap-content >\n<table class=\"wikitable mitan_table\" style=\"text-align: left;\">\n{{{雀部计簿}}}\n</table>\n</div></div>\n\n<div class=drop-down-wrap >\n    <div class=wrap-title>\n    <div class=title>密探传闻<span style=\"position: absolute;right: 5px;font-size: 14px;\">▼展开全部▼</span></div>\n    <div class=\"glyphicon icon-arrow-plus\"></div>\n    </div>\n    <div class=wrap-content >\n<ta